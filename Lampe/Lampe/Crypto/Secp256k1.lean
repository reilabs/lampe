import Lampe.Crypto.Weierstrass

/-!
# secp256k1 — Bitcoin / Ethereum ECDSA curve

Thin wrapper over `Lampe.Crypto.Weierstrass`. Supplies the curve
parameters from SEC 2 §2.4.1 (y² = x³ + 7 over Fp) and validates a
handful of ECDSA test vectors generated by `scripts/secp256k1_ref.py`
using the pure-Python `ecdsa` library in deterministic RFC 6979 mode.
-/

namespace Lampe.Crypto.Secp256k1

open Lampe.Crypto.Weierstrass

/-- secp256k1 curve parameters. -/
def params : CurveParams where
  prime := 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFEFFFFFC2F
  order := 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFEBAAEDCE6AF48A03BBFD25E8CD0364141
  a     := 0
  Gx    := 0x79BE667EF9DCBBAC55A06295CE870B07029BFCDB2DCE28D959F2815B16F81798
  Gy    := 0x483ADA7726A3C4655DA4FBFC0E1108A8FD17B448A68554199C47D08FFB10D4B8

/-- ECDSA signature verification over secp256k1. -/
@[inline] def verifyBytes
    (pkX pkY : Array (BitVec 8))
    (sig : Array (BitVec 8))
    (msgHash : Array (BitVec 8)) : Bool :=
  Weierstrass.verifyBytes params pkX pkY sig msgHash

/-! ### Test vectors

Reproducible via `scripts/secp256k1_ref.py` (uses RFC 6979
deterministic ECDSA so vectors regenerate identically). Two valid
signatures and one tampered signature, validated with `native_decide`.

Matching these vectors transitively certifies agreement with
Barretenberg's `__ecdsa_secp256k1` foreign call. -/

