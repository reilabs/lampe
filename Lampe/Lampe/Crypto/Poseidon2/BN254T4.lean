def pow5 [Mul F] (x : F) : F :=
  let x2 := x * x
  let x4 := x2 * x2
  x * x4

def sboxAll [Mul F] (state : List.Vector F 4) : List.Vector F 4 :=
  state.map pow5

/-- Cheap width-4 external MDS matrix from the Poseidon2 paper/TACEO implementation. -/
def matmulExternal [Add F] (state : List.Vector F 4) : List.Vector F 4 :=
  let a := state.get ⟨0, by decide⟩
  let b := state.get ⟨1, by decide⟩
  let c := state.get ⟨2, by decide⟩
  let d := state.get ⟨3, by decide⟩
  let t0 := a + b
  let t1 := c + d
  let t2 := b + b + t1
  let t3 := d + d + t0
  let t4 := t1 + t1 + t1 + t1 + t3
  let t5 := t0 + t0 + t0 + t0 + t2
  let t6 := t3 + t5
  let t7 := t2 + t4
  vec4 t6 t5 t7 t4

def addRCExternal [Add F] (state rc : List.Vector F 4) : List.Vector F 4 :=
  List.Vector.ofFn fun i => state.get i + rc.get i

def externalRound [Add F] [Mul F]
    (state rc : List.Vector F 4) : List.Vector F 4 :=
  matmulExternal (sboxAll (addRCExternal state rc))

def sum4 [Add F] (state : List.Vector F 4) : F :=
  state.get ⟨0, by decide⟩ +
  state.get ⟨1, by decide⟩ +
  state.get ⟨2, by decide⟩ +
  state.get ⟨3, by decide⟩

/-- Width-4 internal linear layer: `state[i] = state[i] * diag[i] + sum(state)`. -/
def matmulInternal [NatCast F] [Add F] [Mul F]
    (state : List.Vector F 4) : List.Vector F 4 :=
  let total := sum4 state
  let diag := matDiagM1 (F := F)
  List.Vector.ofFn fun i => state.get i * diag.get i + total

def internalRound [NatCast F] [Add F] [Mul F]
    (state : List.Vector F 4) (rc : F) : List.Vector F 4 :=
  let state := state.set ⟨0, by decide⟩ (pow5 (state.get ⟨0, by decide⟩ + rc))
  matmulInternal state

/-- TACEO/Noir BN254 width-4 Poseidon2 permutation. -/
def permutation [NatCast F] [Add F] [Mul F]
    (state : List.Vector F 4) : List.Vector F 4 :=
  let state := matmulExternal state
  let state := (externalRCFirst (F := F)).foldl (fun state rc => externalRound state rc) state
  let state := (internalRC (F := F)).foldl (fun state rc => internalRound state rc) state
  (externalRCSecond (F := F)).foldl (fun state rc => externalRound state rc) state

end Lampe.Crypto.Poseidon2.BN254T4
